# macOS
.DS_Store

# Xcode
build/
DerivedData/
*.xcuserstate
*.xcscmblueprint
xcuserdata/
*.moved-aside

# Swift Package Manager
.build/
.swiftpm/
Package.resolved

# Secrets / config that shouldn't be committed
*.xcconfig.local
GoogleService-Info.plist
AuthKey_*.p8

# Node (contract-test tooling only)
node_modules/
package-lock.json
# ...except the contract test's own lock. CI runs `npm ci`, which REQUIRES a
# committed lock file, and an unpinned ajv means the gate's validation
# behaviour could change under us without any commit saying so.
!scripts/contract/package-lock.json