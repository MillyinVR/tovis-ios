import SwiftUI
import TovisKit

@main
struct TovisApp: App {
    // Point at `.local` while developing against `npm run dev`, `.production`
    // for a real build. (See TovisConfig — set your real prod URL there.)
    @State private var session = SessionModel(config: .local)

    var body: some Scene {
        WindowGroup {
            RootView()
                .environment(session)
        }
    }
}